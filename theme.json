{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": false,
    "color": {
      "custom": true,
      "customDuotone": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "background",
          "name": "Background",
          "color": "#f7f7f7"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#f0eadb"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#1c1c1c"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#d0b985"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "#c8c8c8"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#8a8a8a"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "units": ["px", "rem", "vw", "%"],
      "spacingSizes": [
        {
          "slug": "gutter",
          "name": "Gutter",
          "size": "1rem"
        },
        {
          "slug": "stack",
          "name": "Stack",
          "size": "1.5rem"
        },
        {
          "slug": "section",
          "name": "Section",
          "size": "4rem"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "defaultFontSizes": false,
      "fluid": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Poppins\", sans-serif",
          "name": "Poppins",
          "slug": "primary"
        },
        {
          "fontFamily": "\"Raleway\", sans-serif",
          "name": "Raleway",
          "slug": "secondary"
        }
      ],
      "fontSizes": [
        {
          "slug": "label",
          "name": "Label",
          "size": "0.75rem"
        },
        {
          "slug": "body",
          "name": "Body",
          "size": "1rem"
        },
        {
          "slug": "lead",
          "name": "Lead",
          "size": "1.125rem"
        },
        {
          "slug": "title",
          "name": "Title",
          "size": "1.5rem"
        },
        {
          "slug": "heading-xl",
          "name": "Heading XL",
          "size": "2.5rem"
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "4.5rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--stack)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--secondary)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--primary)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--text)"
        }
      },
      "button": {
        "border": {
          "radius": "var(--re-style-radius)"
        },
        "color": {
          "background": "var(--wp--preset--color--text)",
          "text": "var(--wp--preset--color--accent)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--primary)",
          "fontSize": "var(--wp--preset--font-size--body)",
          "fontWeight": "600",
          "textTransform": "uppercase"
        }
      }
    }
  }
}
